generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OAuthToken {
  id            String   @id @default(cuid())
  provider      String   @default("fanvue")
  accessToken   String
  refreshToken  String?
  expiresIn     Int
  expiresAt     DateTime
  scope         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SyncLog {
  id        String   @id @default(cuid())
  type      String
  status    String   @default("pending")
  message   String?
  startedAt DateTime @default(now())
  finishedAt DateTime?
}

model Discovery {
  id        String   @id @default(cuid())
  refId     String
  title     String
  category  String
  tags      String?
  summary   String?
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
